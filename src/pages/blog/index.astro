---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import BlogCard from "../../components/BlogCard.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);

const featured = posts.filter((p) => p.data.featured);
const rest = posts.filter((p) => !p.data.featured);
---

<BaseLayout
  title="Blog — Cédric Matyja"
  description="Articles sur Astro, TypeScript, architecture front-end et outils web."
>
  <Nav currentPath="/blog" />

  <main class="blog-page">
    <div class="blog-wrapper">
      <header class="blog-header">
        <div class="section-tag">Ecrits</div>
        <h1 class="section-title">Le <em>blog</em></h1>
        <p class="section-sub">
          Je partage ici mes expériences, mes projets et mes réflexions autour
          du développement web et des technologies que j’explore au quotidien.
        </p>
      </header>

      {
        featured.length > 0 && (
          <section class="blog-featured">
            <div class="blog-featured-label">A la une</div>
            <div class="blog-grid-featured">
              {featured.map((post) => (
                <BlogCard slug={post.id} size="lg" {...post.data} />
              ))}
            </div>
          </section>
        )
      }

      {
        rest.length > 0 && (
          <section class="blog-all">
            <div class="blog-featured-label">Tous les articles</div>
            <div class="blog-grid-all">
              {rest.map((post) => (
                <BlogCard slug={post.id} {...post.data} />
              ))}
            </div>
          </section>
        )
      }

      {
        posts.length === 0 && (
          <div class="blog-empty">
            <p>Aucun article pour l'instant. Revenez bientot !</p>
          </div>
        )
      }
    </div>
  </main>
</BaseLayout>

<style>
  .blog-page {
    min-height: 100vh;
    padding: 6rem clamp(2.4rem, 5vw, 8rem) 12rem;
  }

  .blog-wrapper {
    width: 100%;
    max-width: 144rem;
    margin: 0 auto;
  }

  .blog-header {
    max-width: 64rem;
    margin-bottom: 6.4rem;
  }

  .blog-featured-label {
    margin-bottom: 2rem;
    font-family: "DM Mono", monospace;
    font-size: 1.1rem;
    color: var(--text3);
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  .blog-featured {
    margin-bottom: 6.4rem;
  }

  .blog-grid-featured {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(40rem, 1fr));
    gap: 2.4rem;
  }

  .blog-grid-all {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(30rem, 1fr));
    gap: 2rem;
  }

  .blog-empty {
    padding: 8rem 0;
    font-size: 1.5rem;
    color: var(--text3);
    text-align: center;
  }

  @media (width <= 70rem) {
    .blog-grid-featured,
    .blog-grid-all {
      grid-template-columns: 1fr;
    }
  }
</style>
