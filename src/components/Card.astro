---
import type { CardProps } from "../types";

type Props = CardProps & {
  size?: "sm" | "md" | "lg";
  hover?: boolean;
  class?: string;
};

const {
  href,
  title,
  description,
  tags = [],
  coverImage,
  size = "md",
  hover = true,
  class: className = "",
} = Astro.props;
---

<a
  href={href}
  class:list={["card", `card-${size}`, hover && "card-hover", className]}
>
  {
    coverImage && (
      <div class="card-cover">
        <img src={coverImage} alt={title} />
      </div>
    )
  }
  <div class="card-body">
    <h3 class="card-title">{title}</h3>
    <p class="card-desc">{description}</p>
    {
      tags.length > 0 && (
        <div class="card-tags">
          {tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )
    }
  </div>
</a>

<style>
  .card {
    overflow: hidden;
    background: var(--bg3);
    border: 1px solid var(--border2);
    border-radius: var(--radius);
    transition: all 0.3s ease;
  }

  .card-hover:hover {
    border-color: var(--accent);
    box-shadow: 0 0.8rem 2.4rem var(--accent-glow);
    transform: translateY(-0.3rem);
  }

  .card-sm {
    padding: 1.2rem;
  }

  .card-md {
    padding: 1.6rem;
  }

  .card-lg {
    padding: 2rem;
  }

  .dark-mode .card {
    background: rgb(51 65 85 / 50%);
  }

  :root[data-theme="light"] .card {
    background: rgb(241 245 249 / 80%);
  }
</style>
