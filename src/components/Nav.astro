---
import type { NavProps } from "../types";

type Props = NavProps;

const { currentPath = "/" } = Astro.props;
const isHome = currentPath === "/";
---

<nav class="site-nav">
  <div class="site-nav-container">
    <a href="/" class="nav-logo">CM<span>.</span></a>
    <ul class="nav-links">
      {
        isHome ? (
          <>
            <li>
              <a href="#parcours">Parcours</a>
            </li>
            <li>
              <a href="#formation">Formation</a>
            </li>
            <li>
              <a href="#stack">Stack</a>
            </li>
            <li>
              <a href="#projects">Projets</a>
            </li>
            <li>
              <a href="#blog">Blog</a>
            </li>
            <li>
              <a href="#contact" class="nav-cta">
                Contact
              </a>
            </li>
          </>
        ) : (
          <>
            <li>
              <a href="/">Accueil</a>
            </li>
            <li>
              <a href="/blog">Blog</a>
            </li>
            <li>
              <a href="/#contact" class="nav-cta">
                Contact
              </a>
            </li>
          </>
        )
      }
    </ul>
  </div>
</nav>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 900;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 5rem;
    background: var(--nav-bg);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(10px);
  }

  .site-nav-container {
    display: flex;
    flex-direction: row;
    gap: 2rem;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 1440px;
    height: 100%;
    padding: 0 1.5rem;
  }

  .nav-logo {
    font-family: "DM Serif Display", serif;
    font-size: 3rem;
    color: var(--text);
    letter-spacing: -0.05rem;
    text-decoration: none;
  }

  .nav-logo span {
    color: var(--accent2);
  }

  .nav-links {
    display: flex;
    flex-direction: row;
    gap: 0.5rem;
    padding: 0;
    margin: 0;
    margin-left: auto;
    list-style: none;
  }

  .nav-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 3.5rem;
    padding: 0 1.3rem;
    font-size: 1.55rem;
    font-weight: 500;
    color: var(--text3);
    white-space: nowrap;
    text-decoration: none;
    border-radius: 0.4rem;
    transition: all 0.25s ease;
  }

  .nav-links a:hover {
    color: var(--text);
    background: rgb(59 130 246 / 5%);
  }

  :root[data-theme="light"] .nav-links a:hover {
    background: rgb(0 0 0 / 5%);
  }

  .nav-cta {
    font-weight: 500 !important;
    color: #fff !important;
    background: var(--accent) !important;
  }

  .nav-cta:hover {
    opacity: 0.85;
  }

  @media (width <= 900px) {
    .site-nav {
      height: 4rem;
    }

    .site-nav-container {
      gap: 0.6rem;
      padding: 0 0.8rem;
    }

    .nav-links {
      gap: 0.2rem;
      overflow-x: auto;
      scroll-behavior: smooth;
    }

    .nav-links a {
      height: 2.8rem;
      padding: 0 0.7rem;
      font-size: 1.05rem;
    }
  }
</style>
